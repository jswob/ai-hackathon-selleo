{
	"name": "bun-elysia-react-template",
	"type": "module",
	"private": true,
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"api:build": "bun --cwd apps/api build",
		"api:dev": "bun --cwd apps/api dev",
		"api:test": "bun --cwd apps/api test",
		"api:typecheck": "bun --cwd apps/api typecheck",
		"build:api": "bun --cwd apps/api build",
		"build:web": "bun --cwd apps/web build",
		"build": "bun build:web && bun build:api",
		"clean:dist": "rm -rf apps/*/dist apps/*/build",
		"clean:modules": "rm -rf node_modules apps/*/node_modules packages/*/node_modules",
		"clean": "bun clean:modules && bun clean:dist",
		"db:base": "bun --cwd apps/api db:base",
		"db:clean": "bun --cwd apps/api db:clean --force",
		"db:down": "docker-compose stop postgres postgres-test postgres-e2e",
		"db:generate:custom": "bun --cwd apps/api db:generate:custom",
		"db:generate": "bun --cwd apps/api db:generate",
		"db:migrate:status": "bun --cwd apps/api db:migrate:status",
		"db:migrate": "bun --cwd apps/api db:migrate",
		"db:push:safe": "bun --cwd apps/api db:push:safe",
		"db:push": "bun --cwd apps/api db:push",
		"db:reset": "bun --cwd apps/api db:reset",
		"db:restore": "bun --cwd apps/api db:restore",
		"db:schema:check": "bun --cwd apps/api schema:check",
		"db:seed": "bun --cwd apps/api db:seed",
		"db:snapshot:list": "bun --cwd apps/api db:snapshot:list",
		"db:snapshot": "bun --cwd apps/api db:snapshot",
		"db:undo": "bun --cwd apps/api db:undo",
		"db:up": "docker-compose up -d",
		"dev": "concurrently \"bun web:dev\" \"bun api:dev\" --names \"web,api\" --prefix-colors \"blue,green\"",
		"down": "docker-compose down",
		"e2e": "bun --cwd apps/web e2e",
		"e2e:ui": "bun --cwd apps/web e2e:ui",
		"e2e:headed": "bun --cwd apps/web e2e:headed",
		"e2e:install": "bun --cwd apps/web e2e:install",
		"e2e:setup": "bun --cwd apps/api e2e:setup",
		"e2e:restore": "bun --cwd apps/api e2e:restore",
		"format:check": "eslint . --ext .ts,.tsx,.js,.jsx --max-warnings 0 && prettier --check .",
		"format": "eslint . --fix --ext .ts,.tsx,.js,.jsx && prettier --write .",
		"format:prettier": "prettier --write .",
		"format:eslint": "eslint . --fix --ext .ts,.tsx,.js,.jsx",
		"lint:fix": "eslint . --fix --ext .ts,.tsx,.js,.jsx",
		"lint": "eslint . --report-unused-disable-directives --max-warnings 0 && bun typecheck",
		"prepare": "husky",
		"setup": "bun scripts/setup.ts",
		"refresh": "bun clean && bun install",
		"test:api": "bun --cwd apps/api test",
		"test:ui": "bun --cwd apps/api test:setup && vitest --ui",
		"test:watch": "bun --cwd apps/api test:setup && vitest",
		"test:web": "bun --cwd apps/web test:run",
		"test:drizzle-fixtures": "bun --cwd packages/drizzle-fixtures test",
		"test:drizzle-fixtures:integration": "bun --cwd packages/drizzle-fixtures test src/integration",
		"test": "bun --cwd apps/api test:setup && vitest --run",
		"drizzle-fixtures:typecheck": "bun --cwd packages/drizzle-fixtures typecheck",
		"typecheck": "bun drizzle-fixtures:typecheck && bun web:typecheck && bun api:typecheck",
		"up": "docker-compose up -d",
		"web:build": "bun --cwd apps/web build",
		"web:dev": "bun --cwd apps/web dev",
		"web:test": "bun --cwd apps/web test:run",
		"web:typecheck": "bun --cwd apps/web typecheck"
	},
	"devDependencies": {
		"@meetings-scheduler/config": "workspace:*",
		"@types/bun": "^1.1.17",
		"concurrently": "^9.2.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.1.5",
		"vite-tsconfig-paths": "^5.1.4",
		"vitest": "^3.2.4"
	}
}
