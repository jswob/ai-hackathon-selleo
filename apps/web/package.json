{
	"name": "@meetings-scheduler/web",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "tsc -b && vite build",
		"preview": "vite preview",
		"typecheck": "tsc -b --noEmit",
		"test": "vitest",
		"test:ui": "vitest --ui",
		"test:run": "vitest run",
		"e2e": "bun --env-file=../../.env playwright test",
		"e2e:ui": "bun --env-file=../../.env playwright test --ui",
		"e2e:headed": "bun --env-file=../../.env playwright test --headed",
		"e2e:debug": "bun --env-file=../../.env playwright test --debug",
		"e2e:codegen": "bun --env-file=../../.env playwright codegen",
		"e2e:install": "playwright install chromium"
	},
	"dependencies": {
		"@base-ui/react": "^1.2.0",
		"@dnd-kit/core": "^6.3.1",
		"@dnd-kit/sortable": "^10.0.0",
		"@dnd-kit/utilities": "^3.2.2",
		"@elysiajs/eden": "^1.3.2",
		"@floating-ui/react": "^0.27.17",
		"@fontsource-variable/geist": "^5.2.8",
		"@headlessui/react": "^2.2.0",
		"@meetings-scheduler/api": "workspace:*",
		"@tanstack/react-query": "^5.85.3",
		"@tanstack/react-query-devtools": "^5.85.3",
		"@tanstack/react-router": "^1.120.3",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"lucide-react": "^0.577.0",
		"react": "^19.1.1",
		"react-dom": "^19.1.1",
		"shadcn": "^4.0.5",
		"tailwind-merge": "^3.5.0",
		"tw-animate-css": "^1.4.0",
		"zod": "^3.24.2"
	},
	"devDependencies": {
		"@meetings-scheduler/config": "workspace:*",
		"@playwright/test": "^1.50.0",
		"@tailwindcss/vite": "^4.0.0",
		"@tanstack/router-plugin": "^1.120.3",
		"@testing-library/jest-dom": "^6.7.0",
		"@testing-library/react": "^16.3.0",
		"@testing-library/user-event": "^14.6.1",
		"@types/react": "^19.1.10",
		"@types/react-dom": "^19.1.7",
		"@vitejs/plugin-react": "^5.0.0",
		"jsdom": "^26.1.0",
		"tailwindcss": "^4.0.0",
		"typescript": "^5.8.3",
		"vite": "^7.1.2",
		"vitest": "^3.2.4"
	}
}
