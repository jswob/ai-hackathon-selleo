					"frontend test",
					"frontend page",
					"frontend route",
					"react performance",
					"code splitting",
					"lazy loading",
					"memo",
					"react compiler"
				],
				"intentPatterns": [
					"(create|add|build|write|implement).*?(component|hook|page|route)",
					"(create|add|define).*?react.*?(component|hook|context|provider)",
					"(configure|setup|use).*?(tanstack|router|query|eden)",
					"(validate|add validation|zod).*?(form|input|search|params)",
					"(style|add|create).*?(tailwind|cva|variant|theme)",
